{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/gestion", "destination": "/gestion/index.html" },
      { "source": "/gestion/**", "destination": "/gestion/index.html" }
    ]
  }
}
